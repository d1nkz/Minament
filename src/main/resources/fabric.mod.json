{
	"schemaVersion": 1,
	"id": "minament",
	"version": "${version}",
	"name": "minament",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/minament/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "dinkz.minament.Minament",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "dinkz.minament.MinamentClient",
				"adapter": "kotlin"
			}
		],
		"rei_client": [
			"dinkz.minament.rei.MinamentReiPlugin"
		]
	},
	"mixins": [
		"minament.mixins.json",
		{
			"config": "minament.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}